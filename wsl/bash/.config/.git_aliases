# Amend last commit
alias gamend='git commit --amend --verbose'

# List all branches, including origin, by last activity
alias gbranches='git for-each-ref --sort=-committerdate --format="%(HEAD) %(refname:short)  %(committername) %(committerdate:relative)"'

# Delete a local branch
alias gbranchdell='git branch -d'
alias gbranchdl='git branch -d'
alias gdell='git branch -d'
alias gdellocal='git branch -d'
alias gdellocalbranch='git branch -d'

# Delete a remote branch
alias gbranchdelr='git push --delete origin'
alias gbranchdr='git push --delete origin'
alias gdelr='git push --delete origin'
alias gdelremote='git push --delete origin'
alias gdelremotebranch='git push --delete origin'

# Delete both local and remote branches
alias gbranchd='git branch -d && git push --delete origin'
alias gbranchdel='git branch -d && git push --delete origin'
alias gbranchdelete='git branch -d && git push --delete origin'

# Show changes in a commit
alias gdiffcommit='git diff $1~ $1'
# Show diff of versions N1 and N2
alias gdiffv='git diff head~$1..head~$2'
# Show inline diff of current changes
alias gdiffinline='git diff --word-diff'
alias gdiffthis='git diff --word-diff'
# Show log, including files
alias glogfiles='git log --name-status'
alias glogstat='git log --stat'
# Push new branch to origin
alias gpushnew='git push --set-upstream origin $(git rev-parse --abbrev-ref HEAD)'
# Refresh tags stale relative to origin
alias grefreshtags='git fetch --prune origin "+refs/tags/*:refs/tags/*"'

# Show last commit
alias glast='git log -1'

# Show current branch
alias gcurrent='git rev-parse --abbrev-ref HEAD'

# Show branch ahead/behind
alias gaheadbehind='git status -sb'

# Show untracked files
alias guntracked='git ls-files --others --exclude-standard'

# Clean up merged branches (delete local branches already merged to current)
alias gcleanmerged='git branch --merged | grep -v "\\*" | xargs -n 1 git branch -d'

# List contents of all stashes
alias gstashlog="git stash list --pretty=format:'${GIT_FORMAT4}'"

# Unadd a file
alias gunadd='git reset HEAD --'

# Functions

gitMergeFrom() {
  # Update current branch with changes from given branch
  local branch="$1"
  if [[ -z "$branch" ]]; then
    echo "Usage: gmergefrom <branch>"
    return 1
  fi
  git stash
  git branch -D "$branch" 2>/dev/null
  git fetch origin "$branch"
  git branch "$branch" "origin/$branch"
  git rebase "$branch"
  git stash pop || true
}
alias gmergefrom='gitMergeFrom'
alias gmergedev='gitMergeFrom development'
alias gmergemaster='gitMergeFrom master'

gitRenameBranch() {
  # Rename the current branch to a new name ($1), both locally and on the 'origin' remote.
  local old_name=$(git rev-parse --abbrev-ref HEAD)
  local new_name="$1"

  if [[ -z "$new_name" ]]; then
    echo "Usage: grename <new-branch-name>"
    return 1
  fi

  git branch -m "$new_name" || return 1
  git push origin --delete "$old_name" || echo "Remote branch delete failed or not needed."
  git push --set-upstream origin "$new_name"
}
alias grename='gitRenameBranch'

alias ggraph="git log --graph --all --abbrev-commit --pretty=format:'${GIT_FORMAT1}'"
alias ggraph2="git log --graph --all --abbrev-commit --format=format:'${GIT_FORMAT2}' --name-only"
alias ggraph3="git log --graph --all --abbrev-commit --pretty=format:'${GIT_FORMAT3}' --name-only"

multigraph() {
  # multigraph n: show n lines of each graph
  find . -mindepth 1 -maxdepth 1 -type d -print -exec git -C {} log -n "$1" --graph --all --abbrev-commit --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%Creset' \; -exec echo \; -exec echo \;
}
multigraph2() {
  find . -mindepth 1 -maxdepth 1 -type d -print -exec git -C {} log -n "$1" --graph --all --format=format:"${GIT_FORMAT2}" --abbrev-commit \; -exec echo \; -exec echo \;
}
multifind() {
  # find commits having comments containing string $1
  find . -mindepth 1 -maxdepth 1 -type d -print -exec git -C {} log -i --grep "$1" \; -exec echo \; -exec echo \;
}

gitCheckout() {
  # checkout branch $1
  git checkout "$1"
}
alias gcheckm='gitCheckout master'

gitPushd() {
  # save current branch name
  export tmp=$(git rev-parse --abbrev-ref HEAD)
}
alias gpushd='gitPushd'
gitPopd() {
  # checkout branch with saved name
  git checkout "$tmp"
  unset tmp
}
alias gpopd='gitPopd'

gitRefetch() {
  # resync branch with origin
  local branch="$1"
  if [[ -z "$branch" ]]; then
    echo "Usage: gremaster <branch>"
    return 1
  fi
  git branch -D "$branch" 2>/dev/null
  git fetch origin "$branch"
  git branch "$branch" "origin/$branch"
}
alias gremaster='gitRefetch master'

multigit() {
  cmd="$*"
  find . \
    -type d \( -name 'node_modules' -o -name 'build' -o -name 'dist' \) -prune -o \
    -type d -name '.git' -print \
    | sed 's|/\.git$||' \
    | parallel --no-notice --halt soon,fail=1 'echo "{}"; git -C "{}" '"$cmd"
}
alias multipull='multigit pull'
alias multireset='multigit reset --hard'
alias multimaster='multigit checkout master'
alias multistat='multigit status'
alias multiprune='multigit remote prune origin'
alias multitag='multigit fetch --prune origin "+refs/tags/*:refs/tags/*"'
alias multigc='multigit gc'

gitListFiles() {
  # list all git files with their last commit details
  for file in $(git ls-files); do
    echo -e "${C_PATH}$file${C_RESET}"
    git log -1 --pretty="format:${GIT_FORMAT3}" --date=short -- "$file"
  done
}
alias gdetails='gitListFiles'
alias gfile='gitListFiles'
alias gfiledetails='gitListFiles'

gitListFiles2() {
  for file in $(git ls-files); do
    echo -e "${C_PATH}$file${C_RESET} | $(git log -1 --color=always --pretty="format:${GIT_FORMAT3}" --date=short -- "$file")"
  done
}
alias gdetails2='gitListFiles2'
alias gfile2='gitListFiles2'
alias gfiledetails2='gitListFiles2'

gitListFiles3() {
  # Default sort column and order
  sort_col=1
  sort_order=""
  sort_name="Date"
  fg_colors=("$WHITE" "$YELLOW" "$GREEN" "$YELLOW")
  bg_colors=("$CYAN_BG" "$YELLOW_BG" "$GREEN_BG" "$YELLOW_BG")

  # Parse flag
  case "$1" in
    -d)  sort_col=1; sort_order=""; sort_name="Date" ;;
    -dr) sort_col=1; sort_order="-r"; sort_name="Date" ;;
    -c)  sort_col=3; sort_order=""; sort_name="Commit" ;;
    -cr) sort_col=3; sort_order="-r"; sort_name="Commit" ;;
    -a)  sort_col=4; sort_order=""; sort_name="Author" ;;
    -ar) sort_col=4; sort_order="-r"; sort_name="Author" ;;
    -f)  sort_col=5; sort_order=""; sort_name="File" ;;
    -fr) sort_col=5; sort_order="-r"; sort_name="File" ;;
    *)
      echo "Usage: git_file_commits [-d|-dr|-c|-cr|-a|-ar|-f|-fr]"
      echo "  -d   : sort by date"
      echo "  -dr  : sort by date (reverse)"
      echo "  -c   : sort by commit hash"
      echo "  -cr  : sort by commit hash (reverse)"
      echo "  -a   : sort by author"
      echo "  -ar  : sort by author (reverse)"
      echo "  -f   : sort by file name"
      echo "  -fr  : sort by file name (reverse)"
      return 1
      ;;
  esac

  repo_root=$(git rev-parse --show-toplevel)
  current_dir=$(pwd)
  rel_prefix=${current_dir#$repo_root/}

  # Determine which column to highlight
  # Index: 0=Date, 1=Commit, 2=Author, 3=File
  highlight_idx=0
  case "$sort_col" in
    1) highlight_idx=0 ;;
    3) highlight_idx=1 ;;
    4) highlight_idx=2 ;;
    5) highlight_idx=3 ;;
  esac

  # Print header with highlight
  header=("Date" "Commit" "Author" "File")
  for i in {0..3}; do
    if [ "$i" -eq "$highlight_idx" ]; then
      printf "${BOLD}${BLACK}${bg_colors[$i]}%-30s${RESET} " "${header[$i]}"
    else
      printf "${BOLD}${fg_colors[$i]}%-30s${RESET} " "${header[$i]}"
    fi
  done
  printf "\n"

  git log --pretty=format:'%cI|%ad|%h|%an' --name-only -- . | \
  awk -F'|' '
    NF == 4 { # commit info line
      date_iso = $1
      date_pretty = $2
      commit_hash = $3
      author = $4
      next
    }
    NF == 1 && $1 != "" { # file line
      file = $1
      if (!(file in seen)) {
        seen[file] = 1
        print date_iso "|" date_pretty "|" commit_hash "|" author "|" file
      }
    }
  ' | sort -t'|' -k"$sort_col" $sort_order | while IFS="|" read date_iso date_pretty commit_hash author file; do
    # Remove prefix from file path
    rel_file="$file"
    if [[ -n "$rel_prefix" && "$rel_file" == "$rel_prefix/"* ]]; then
      rel_file="${rel_file#$rel_prefix/}"
    elif [[ -n "$rel_prefix" && "$rel_file" == "$rel_prefix"* ]]; then
      rel_file="${rel_file#$rel_prefix}"
    fi

    # Prepare columns
    cols=("$date_pretty" "$commit_hash" "$author" "$rel_file")
    for i in {0..3}; do
      if [ "$i" -eq "$highlight_idx" ]; then
        printf "${BLACK}${bg_colors[$i]}%-30s${RESET} " "${cols[$i]}"
      else
        printf "${fg_colors[$i]}%-30s${RESET} " "${cols[$i]}"
      fi
    done
    printf "\n"
  done
}
alias gdetails3='gitListFiles3'
alias gfile3='gitListFiles3'
alias gfiledetails3='gitListFiles3'


# Shell compatibility check (warn instead of exit)

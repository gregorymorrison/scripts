#!/bin/bash

# Color definitions
C_LABEL='\033[0;32m'
C_PATH='\033[1;33m'
C_RESET='\033[0m'
GIT_FORMAT1="%C(red)%h%C(reset) - %C(yellow)%d%C(reset) %s %C(green)(%cr)%C(reset)"
GIT_FORMAT2="%C(bold yellow)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n          %C(white)%s%C(reset) %C(bold white)- %an%C(reset)%n"
GIT_FORMAT3="%C(red)%h%C(reset) %C(yellow)%ad%C(reset) | %C(blue)%an%C(reset) | %C(cyan)%s%C(reset)"
GIT_FORMAT4="%C(red)%h%C(reset) - %C(dim yellow)(%C(bold magenta)%gd%C(dim yellow))%C(reset) %<(70,trunc)%s %C(green)(%cr) %C(bold blue)<%an>%C(reset)"

